<Window x:Class="SecureVault.PasswordPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Required" Height="220" Width="420"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border Background="#141414" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#111111" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock x:Name="TitleText" Text="Password Required"
                           Foreground="#E8E8E8" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="18,0"/>
            </Border>

            <StackPanel Grid.Row="1" Margin="22,18,22,0">
                <TextBlock x:Name="BodyText"
                           Text="Enter the password used to create this encrypted share."
                           Foreground="#888888" FontSize="13" TextWrapping="Wrap"
                           Margin="0,0,0,12"/>
                <PasswordBox x:Name="PasswordBox" Height="34"
                             Background="#252525" Foreground="#E8E8E8"
                             BorderBrush="#3A3A3A" BorderThickness="1"
                             Padding="10,0" PasswordChar="*"
                             KeyDown="PasswordBox_KeyDown"/>
            </StackPanel>

            <DockPanel Grid.Row="2" Margin="18,10,18,16" LastChildFill="False">
                <Button Content="Cancel" Width="90" Height="30" DockPanel.Dock="Right"
                        Margin="8,0,0,0" Click="Cancel_Click"/>
                <Button Content="Import" Width="90" Height="30" DockPanel.Dock="Right"
                        Click="Confirm_Click"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
