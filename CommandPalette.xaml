<Window x:Class="SecureVault.CommandPalette"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560" Height="400" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Topmost="True">
    <Border CornerRadius="10" Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1">
        <DockPanel>
            <Border DockPanel.Dock="Top" Padding="14,12" Background="#222222" CornerRadius="10,10,0,0">
                <TextBox x:Name="SearchInput" Background="Transparent" BorderThickness="0"
                         Foreground="#E8E8E8" CaretBrush="#7C3AED" FontSize="15"
                         SelectionBrush="#7C3AED"
                         TextChanged="SearchInput_TextChanged"
                         KeyDown="SearchInput_KeyDown"/>
            </Border>
            <ListBox x:Name="ResultsList" Background="Transparent" BorderThickness="0"
                     Foreground="#CCCCCC" FontSize="13"
                     KeyDown="ResultsList_KeyDown"
                     MouseDoubleClick="ResultsList_Execute">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#CCCCCC"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#2D2D2D"/>
                                            <Setter Property="Foreground" Value="#E8E8E8"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#7C3AED"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Icon}" FontSize="14" Width="24" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Sub}" FontSize="11" Foreground="#666666"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Shortcut}" FontSize="11" Foreground="#444444"
                                       VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
