<Window x:Class="SecureVault.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bastion"
        Width="820" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Grid>
        <!-- Full dark background -->
        <Rectangle Fill="#0D0D0D"/>

        <!-- Purple glow top-right -->
        <Ellipse Width="500" Height="500"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,-200,-150,0" Opacity="0.08">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#7C3AED" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Purple glow bottom-left -->
        <Ellipse Width="400" Height="400"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                 Margin="-100,0,0,-150" Opacity="0.06">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#6D28D9" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Drag - whole window -->
        <Rectangle Fill="Transparent" MouseLeftButtonDown="TitleBar_MouseDown"/>

        <!-- Close button -->
        <Button Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,8,0" Cursor="Hand" Click="Close_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#555555"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <TextBlock Text="✕" Foreground="{TemplateBinding Foreground}"
                                               FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2A"/>
                                        <Setter Property="Foreground" Value="#AAAAAA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>

        <!-- Two-column layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Branding -->
            <Border Grid.Column="0" Background="#111111">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="68" Height="68" CornerRadius="14" HorizontalAlignment="Center" Margin="0,0,0,22">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C3AED" Offset="0"/>
                                <GradientStop Color="#4C1D95" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🔒" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Bastion" FontSize="26" FontWeight="Bold"
                               Foreground="#DCDDDE" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                    <TextBlock Text="Your encrypted knowledge base"
                               FontSize="12" Foreground="#484848" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <Rectangle Height="1" Width="100" Fill="#222222" Margin="0,28,0,28"/>
                    <StackPanel HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Ellipse Width="5" Height="5" Fill="#7C3AED" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="AES-256 encrypted vault" Foreground="#444444" FontSize="12" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Ellipse Width="5" Height="5" Fill="#7C3AED" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Obsidian-style notes editor" Foreground="#444444" FontSize="12" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Ellipse Width="5" Height="5" Fill="#7C3AED" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Password manager" Foreground="#444444" FontSize="12" FontFamily="Segoe UI"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Ellipse Width="5" Height="5" Fill="#7C3AED" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Live crypto tracker" Foreground="#444444" FontSize="12" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- RIGHT: Login form -->
            <Border Grid.Column="1" Background="#0D0D0D">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="290">
                    <TextBlock Text="Welcome back"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="#DCDDDE" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                    <TextBlock Text="Enter your master password to unlock your vault."
                               FontSize="12" Foreground="#555555" FontFamily="Segoe UI"
                               TextWrapping="Wrap" Margin="0,0,0,30"/>

                    <TextBlock Text="MASTER PASSWORD" FontSize="10" FontWeight="SemiBold"
                               Foreground="#555555" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,6">
                        <Border CornerRadius="6" BorderThickness="1" BorderBrush="#2D2D2D" Background="#161616">
                            <PasswordBox x:Name="PasswordBox"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#DCDDDE" CaretBrush="#7C3AED"
                                         FontSize="14" Padding="12,11"
                                         PasswordChar="●" FontFamily="Segoe UI"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         KeyDown="PasswordBox_KeyDown"/>
                        </Border>
                        <TextBlock x:Name="PasswordWatermark"
                                   Text="Enter master password"
                                   Foreground="#3D3D3D" FontSize="14"
                                   FontFamily="Segoe UI" Margin="13,12,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <TextBlock x:Name="StatusText" Foreground="#EF4444"
                               FontSize="12" FontFamily="Segoe UI"
                               Margin="0,4,0,14" Visibility="Collapsed"/>

                    <Button x:Name="LoginButton" Content="Unlock Vault"
                            Height="42" FontSize="14" FontWeight="SemiBold"
                            FontFamily="Segoe UI" BorderThickness="0" Cursor="Hand"
                            Click="Login_Click" Margin="0,8,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#7C3AED"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#6D28D9"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#5B21B6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock HorizontalAlignment="Center" Margin="0,14,0,0">
                        <Hyperlink Click="Forgot_Click" Foreground="#3D3D3D" TextDecorations="None">
                            Forgot master password?
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
