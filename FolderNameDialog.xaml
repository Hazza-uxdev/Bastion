<Window x:Class="SecureVault.FolderNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" Height="160"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="Transparent">
    <Border CornerRadius="10" Background="#1A1A1A" BorderBrush="#2D2D2D" BorderThickness="1">
        <StackPanel Margin="24,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="📁" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="New Folder" FontSize="15" FontWeight="SemiBold"
                           Foreground="#E8E8E8" VerticalAlignment="Center"/>
            </StackPanel>
            <Border CornerRadius="5" BorderBrush="#3A3A3A" BorderThickness="1" Background="#252525" Margin="0,0,0,16">
                <TextBox x:Name="FolderBox" Background="Transparent" BorderThickness="0"
                         Foreground="#E8E8E8" CaretBrush="#7C3AED"
                         Padding="10,8" FontSize="13" SelectionBrush="#7C3AED"
                         KeyDown="FolderBox_KeyDown"/>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Height="32" Margin="0,0,8,0" Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#777777"/>
                            <Setter Property="BorderBrush" Value="#333333"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Create" Width="80" Height="32" Click="Create_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#7C3AED"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6D28D9"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
