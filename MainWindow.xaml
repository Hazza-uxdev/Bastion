<Window x:Class="SecureVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bastion" Height="700" Width="1200"
        MinHeight="600" MinWidth="900"
        FontFamily="Segoe UI" Background="#161616"
        WindowStyle="None" AllowsTransparency="True"
        StateChanged="Window_StateChanged">

    <Window.Resources>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent" CornerRadius="5" Margin="4,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#BBBBBB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
        </Style>

        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6D28D9"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#5B21B6"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                                <Setter Property="BorderBrush" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3D1515"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A0A0A"/>
                                <Setter Property="BorderBrush" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="16" Height="16"
                                    Background="#1A1A1A"
                                    BorderBrush="#777777"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check"
                                      Data="M 2.5 7.5 L 6.2 11 L 13 4"
                                      Stroke="#BDBDBD"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="4,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Properly styled dark input - fixes search text visibility -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="CaretBrush" Value="#7C3AED"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionBrush" Value="#7C3AED"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter TargetName="Bd" Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkList" TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>

        <Style x:Key="IntegratedScrollBarThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBg"
                                Background="#343434"
                                CornerRadius="4"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBg" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBg" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IntegratedVerticalScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource IntegratedScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IntegratedHorizontalScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource IntegratedScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource IntegratedScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource IntegratedScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PasswordListScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    Margin="{TemplateBinding Padding}"/>
                            <ScrollBar Grid.Column="1" Grid.Row="0"
                                       Style="{StaticResource IntegratedVerticalScrollBar}"
                                       Orientation="Vertical"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                            <ScrollBar Grid.Column="0" Grid.Row="1"
                                       Style="{StaticResource IntegratedHorizontalScrollBar}"
                                       Orientation="Horizontal"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Value="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordList" TargetType="ListView" BasedOn="{StaticResource DarkList}"/>

        <Style x:Key="DarkListItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Margin="0,1" Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter TextElement.Foreground="{TemplateBinding Foreground}"
                                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#222222"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2D2D2D"/>
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NoteFileItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Margin="2,1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#222222"/>
                                <Setter Property="Foreground" Value="#BBBBBB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2D2D2D"/>
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox with working popup using correct WPF PART_ names -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="#252525"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="10,0,4,0"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"
                                                      TextElement.Foreground="#E8E8E8"/>
                                    <Path Grid.Column="1"
                                          x:Name="Arrow"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 5 5 L 10 0 Z"
                                          Fill="#666666"/>
                                    <ToggleButton Grid.Column="0"
                                                  Grid.ColumnSpan="2"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Opacity="0"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border x:Name="DropBorder"
                                        Background="#252525"
                                        BorderBrush="#3A3A3A"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="220"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter TargetName="Arrow" Property="Fill" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#CCCCCC"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bg"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#333333"/>
                                            <Setter Property="Foreground" Value="#E8E8E8"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#7C3AED"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="RootBorder" BorderBrush="#2A2A2A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0" Background="#141414" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="Bastion" Foreground="#444444" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="—" Width="28" Height="22" Margin="2,0" Click="Minimize_Click"
                                Style="{StaticResource GhostBtn}" Padding="0,0" FontSize="12"/>
                        <Button Content="⬜" Width="28" Height="22" Margin="2,0" Click="Maximize_Click"
                                Style="{StaticResource GhostBtn}" Padding="0,0" FontSize="10"/>
                        <Button Content="✕" Width="28" Height="22" Margin="2,0" Click="CloseApp_Click"
                                Style="{StaticResource DangerBtn}" Padding="0,0" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0">
                        <TextBlock Text="🔒" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- APP BODY -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="#141414">
                    <DockPanel>
                        <Button DockPanel.Dock="Bottom" Content="🔒  Lock Vault"
                                Style="{StaticResource NavButton}" Margin="8,8" Click="Lock_Click"/>
                        <StackPanel Margin="8,14,8,0">
                            <TextBlock Text="BASTION" Foreground="#333333" FontSize="9"
                                       FontWeight="SemiBold" Margin="14,0,0,14"/>
                            <Border x:Name="NavHomeBg" CornerRadius="5" Margin="4,1">
                                <Button x:Name="BtnHome" Content="🏠  Home" Style="{StaticResource NavButton}" Click="Home_Click"/>
                            </Border>
                            <Border x:Name="NavPasswordBg" CornerRadius="5" Margin="4,1">
                                <Button x:Name="BtnPasswordManager" Content="🔐  Passwords" Style="{StaticResource NavButton}" Click="PasswordManager_Click"/>
                            </Border>
                            <Border x:Name="NavNotesBg" CornerRadius="5" Margin="4,1">
                                <Button x:Name="BtnNotes" Content="📝  Notes" Style="{StaticResource NavButton}" Click="Notes_Click"/>
                            </Border>
                            <Border x:Name="NavGraphBg" CornerRadius="5" Margin="4,1">
                                <Button x:Name="BtnGraph" Content="🕸  Graph" Style="{StaticResource NavButton}" Click="Graph_Click"/>
                            </Border>
                            <Border x:Name="NavSecurityBg" CornerRadius="5" Margin="4,1">
                                <Button x:Name="BtnSecurity" Content="🛡  Security" Style="{StaticResource NavButton}" Click="Security_Click"/>
                            </Border>
                            <Border x:Name="NavTrashBg" CornerRadius="5" Margin="4,1">
                                <Button x:Name="BtnTrash" Content="🗑  Trash" Style="{StaticResource NavButton}" Click="Trash_Click"/>
                            </Border>
                            <Rectangle Height="1" Fill="#222222" Margin="8,12"/>
                            <Border x:Name="NavSettingsBg" CornerRadius="5" Margin="4,1">
                                <Button x:Name="BtnSettings" Content="⚙  Settings" Style="{StaticResource NavButton}" Click="Settings_Click"/>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- CONTENT -->
                <Grid Grid.Column="1">

                    <!-- HOME -->
                    <Grid x:Name="HomeView" Visibility="Collapsed" Background="#161616">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="40,32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="340"/>
                                </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,28,0">
                                <TextBlock x:Name="HomeGreeting" Text="Good morning" FontSize="28"
                                           FontWeight="SemiBold" Foreground="#E8E8E8" Margin="0,0,0,6"/>
                                <TextBlock Text="Here's your vault overview." FontSize="14"
                                           Foreground="#555555" Margin="0,0,0,16"/>
                                <!-- Global search Ctrl+K -->
                                <Border CornerRadius="6" BorderBrush="#3A3A3A" BorderThickness="1"
                                        Background="#1E1E1E" Margin="0,0,0,28" MaxWidth="440" HorizontalAlignment="Left">
                                    <DockPanel>
                                        <TextBlock Text="⌕" DockPanel.Dock="Left" Foreground="#555555"
                                                   FontSize="16" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock DockPanel.Dock="Right" Text="Ctrl+K" Foreground="#444444"
                                                   FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBox x:Name="GlobalSearchBox" Background="Transparent"
                                                 BorderThickness="0" Foreground="#E8E8E8"
                                                 CaretBrush="#7C3AED" SelectionBrush="#7C3AED"
                                                 FontSize="13" Padding="10,10"
                                                 TextChanged="GlobalSearch_TextChanged"/>
                                    </DockPanel>
                                </Border>
                                <!-- Search results (hidden when empty) -->
                                <Border x:Name="GlobalSearchResults" Visibility="Collapsed"
                                        CornerRadius="6" BorderBrush="#2A2A2A" BorderThickness="1"
                                        Background="#1C1C1C" Margin="0,0,0,20" MaxWidth="440" HorizontalAlignment="Left">
                                    <ListBox x:Name="GlobalResultsList" Background="Transparent"
                                             BorderThickness="0" MaxHeight="280"
                                             ItemContainerStyle="{StaticResource NoteFileItem}"
                                             MouseDoubleClick="GlobalResult_DoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Icon}" FontSize="13" Width="22" VerticalAlignment="Center"/>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#BBBBBB"/>
                                                        <TextBlock Text="{Binding Sub}" FontSize="11" Foreground="#555555"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                                    <Border Width="180" Height="110" CornerRadius="8" Background="#1C1C1C"
                                            Margin="0,0,16,0" BorderBrush="#2A2A2A" BorderThickness="1">
                                        <StackPanel VerticalAlignment="Center" Margin="20,0">
                                            <TextBlock Text="🔐" FontSize="22" Margin="0,0,0,8"/>
                                            <TextBlock x:Name="PasswordCountText" Text="0" FontSize="32"
                                                       FontWeight="Bold" Foreground="#E8E8E8"/>
                                            <TextBlock Text="Passwords" FontSize="12" Foreground="#555555"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Width="180" Height="110" CornerRadius="8" Background="#1C1C1C"
                                            Margin="0,0,16,0" BorderBrush="#2A2A2A" BorderThickness="1">
                                        <StackPanel VerticalAlignment="Center" Margin="20,0">
                                            <TextBlock Text="📝" FontSize="22" Margin="0,0,0,8"/>
                                            <TextBlock x:Name="NoteCountText" Text="0" FontSize="32"
                                                       FontWeight="Bold" Foreground="#E8E8E8"/>
                                            <TextBlock Text="Notes" FontSize="12" Foreground="#555555"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="RECENT NOTES" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#444444" Margin="0,0,0,12"/>
                                <ListBox x:Name="RecentNotesList" Background="Transparent" BorderThickness="0"
                                         ItemContainerStyle="{StaticResource NoteFileItem}"
                                         MouseDoubleClick="RecentNotes_DoubleClick">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#BBBBBB"/>
                                                <TextBlock Text="{Binding UpdatedAt, StringFormat={}{0:MMM d, yyyy}}"
                                                           FontSize="11" Foreground="#555555"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="QUICK ACTIONS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#444444" Margin="0,28,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="+ New Note" Style="{StaticResource ToolbarBtn}"
                                            Margin="0,0,8,0" Click="QuickNewNote_Click"/>
                                    <Button Content="+ Add Password" Style="{StaticResource GhostBtn}"
                                            Margin="0,0,8,0" Click="Add_Click"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1" CornerRadius="8" Background="#1C1C1C"
                                    BorderBrush="#2A2A2A" BorderThickness="1"
                                    Padding="18" VerticalAlignment="Top">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,14">
                                        <TextBlock Text="Release Timeline" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="#E8E8E8" DockPanel.Dock="Left"
                                                   Margin="0,0,15,0"/>
                                        <TextBlock Text="Latest: v2.9.15" FontSize="11" Foreground="#7C3AED"
                                                   DockPanel.Dock="Right" VerticalAlignment="Center"/>
                                    </DockPanel>

                                    <StackPanel>
                                        <Border BorderBrush="#7C3AED" BorderThickness="2,0,0,0" Padding="12,0,0,0" Margin="0,0,0,18">
                                            <StackPanel>
                                                <TextBlock Text="v2.9.15" FontSize="13" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                                <TextBlock Text="Sidebar navigation state fix" FontSize="11" Foreground="#555555" Margin="0,2,0,8"/>
                                                <TextBlock Text="- Moved active sidebar highlight to explicit named row backgrounds&#x0a;- Kept nav buttons transparent so stale button styles cannot highlight Home&#x0a;- Active tab now follows the visible page directly"
                                                           TextWrapping="Wrap" FontSize="12" Foreground="#BBBBBB"/>
                                            </StackPanel>
                                        </Border>

                                        <Border BorderBrush="#333333" BorderThickness="2,0,0,0" Padding="12,0,0,0" Margin="0,0,0,18">
                                            <StackPanel>
                                                <TextBlock Text="v2.9.14" FontSize="13" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                                                <TextBlock Text="Settings control polish" FontSize="11" Foreground="#555555" Margin="0,2,0,8"/>
                                                <TextBlock Text="- Removed accent-colored checkbox fill and border from Settings&#x0a;- Fixed nav highlight by deriving active tab from the visible page&#x0a;- Stopped active navigation state relying on stale styles"
                                                           TextWrapping="Wrap" FontSize="12" Foreground="#BBBBBB"/>
                                            </StackPanel>
                                        </Border>

                                        <Border BorderBrush="#333333" BorderThickness="2,0,0,0" Padding="12,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="v2.9.13" FontSize="13" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                                                <TextBlock Text="Password toolbar theme fix" FontSize="11" Foreground="#555555" Margin="0,2,0,8"/>
                                                <TextBlock Text="- Fixed Password Manager search box carrying light colors into dark mode&#x0a;- Explicitly themed Password Manager action buttons after theme changes&#x0a;- Improved dark/light contrast for password toolbar controls"
                                                           TextWrapping="Wrap" FontSize="12" Foreground="#999999"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- PASSWORD MANAGER -->
                    <Grid x:Name="PasswordManagerView" Visibility="Collapsed" Background="#161616">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="PasswordHeader" Grid.Row="0" Background="#141414" Padding="16,10">
                            <DockPanel>
                                <TextBlock Text="Password Manager" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#E8E8E8" VerticalAlignment="Center" DockPanel.Dock="Left"
                                           Margin="0,0,40,0"/>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                    <TextBox x:Name="SearchBox" Width="200" Height="30" Margin="0,0,10,0"
                                             Style="{StaticResource DarkInput}"
                                             TextChanged="SearchBox_TextChanged"/>
                                    <Button x:Name="PasswordAddButton" Content="+ Add" Style="{StaticResource ToolbarBtn}" Margin="0,0,6,0" Click="Add_Click"/>
                                    <Button x:Name="PasswordEditButton" Content="Edit" Style="{StaticResource GhostBtn}" Margin="0,0,6,0" Click="Edit_Click"/>
                                    <Button x:Name="PasswordDeleteButton" Content="Delete" Style="{StaticResource DangerBtn}" Margin="0,0,6,0" Click="Delete_Click"/>
                                    <Button x:Name="PasswordCopyButton" Content="Copy" Style="{StaticResource GhostBtn}" Margin="0,0,6,0" Click="Copy_Click"/>
                                    <Button x:Name="PasswordCopyTotpButton" Content="Copy 2FA" Style="{StaticResource GhostBtn}" Margin="0,0,6,0" Click="CopyTotp_Click"/>
                                    <Button x:Name="PasswordImportCsvButton" Content="Import CSV" Style="{StaticResource GhostBtn}" Click="ImportCsv_Click"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <Border x:Name="PasswordContent" Grid.Row="1" Padding="16">
                            <DockPanel>
                            <DockPanel.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource IntegratedVerticalScrollBar}"/>
                            </DockPanel.Resources>
                            <WrapPanel x:Name="PasswordTagsPanel" DockPanel.Dock="Top" Margin="0,0,0,10"/>
                            <ListView x:Name="VaultList" Style="{StaticResource PasswordList}"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ItemContainerStyle="{StaticResource DarkListItem}">
                                <ListView.View>
                                    <GridView>
                                        <GridView.ColumnHeaderContainerStyle>
                                            <Style TargetType="GridViewColumnHeader">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#555555"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="8,6"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                <TextBlock Text="{TemplateBinding Content}"
                                                                           Foreground="#555555" FontSize="11" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GridView.ColumnHeaderContainerStyle>
                                        <GridViewColumn Header="TITLE" Width="220" DisplayMemberBinding="{Binding Title}"/>
                                        <GridViewColumn Header="USERNAME" Width="220" DisplayMemberBinding="{Binding Username}"/>
                                        <GridViewColumn Header="TAGS" Width="160" DisplayMemberBinding="{Binding TagsText}"/>
                                        <GridViewColumn Header="2FA" Width="120" DisplayMemberBinding="{Binding TotpDisplay}"/>
                                        <GridViewColumn Header="PASSWORD" Width="220" DisplayMemberBinding="{Binding MaskedPassword}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- NOTES (3-panel) -->
                    <Grid x:Name="NotesView" Visibility="Collapsed" Background="#161616">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240" MinWidth="180" MaxWidth="340"/>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="280" MinWidth="180"/>
                        </Grid.ColumnDefinitions>

                        <!-- FILE TREE -->
                        <Border Grid.Column="0" Background="#141414">
                            <DockPanel>
                                <!-- Header with New Note + New Folder -->
                                <Border DockPanel.Dock="Top" Padding="12,10,8,8">
                                    <DockPanel>
                                        <TextBlock Text="Notes" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#777777" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                            <Button Content="📁" Width="26" Height="26" FontSize="13"
                                                    Style="{StaticResource NavButton}"
                                                    Foreground="#777777" Click="NewFolder_Click"
                                                    ToolTip="New folder" Padding="0"/>
                                            <Button Content="+" Width="26" Height="26" FontSize="18"
                                                    Style="{StaticResource NavButton}"
                                                    Foreground="#7C3AED" Click="NewNote_Click"
                                                    ToolTip="New note" Padding="0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <!-- Search -->
                                <Border DockPanel.Dock="Top" Padding="8,0,8,6">
                                    <TextBox x:Name="NotesSearchBox" Height="28" Style="{StaticResource DarkInput}"
                                             FontSize="12" Padding="8,0" TextChanged="NotesSearchBox_TextChanged"/>
                                </Border>
                                <!-- Sort bar -->
                                <Border DockPanel.Dock="Top" Padding="8,0,8,6">
                                    <ComboBox x:Name="SortCombo" Style="{StaticResource DarkCombo}"
                                              Height="26" FontSize="11"
                                              SelectionChanged="SortCombo_Changed">
                                        <ComboBoxItem Content="Last edited" IsSelected="True"/>
                                        <ComboBoxItem Content="Created date"/>
                                        <ComboBoxItem Content="Alphabetical"/>
                                        <ComboBoxItem Content="Last edited ↑"/>
                                        <ComboBoxItem Content="Created date ↑"/>
                                        <ComboBoxItem Content="Alphabetical ↑"/>
                                    </ComboBox>
                                </Border>
                                <!-- Notes list (folder-aware) -->
                                <ScrollViewer>
                                    <StackPanel>
                                        <!-- Tag filter chips -->
                                        <Border x:Name="TagFilterBorder" Padding="4,4,4,0" Visibility="Collapsed">
                                            <WrapPanel x:Name="AllTagsPanel"/>
                                        </Border>
                                        <ListBox x:Name="NotesTree" Background="Transparent" BorderThickness="0"
                                                 SelectionChanged="NotesTree_SelectionChanged"
                                                 ItemContainerStyle="{StaticResource NoteFileItem}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  AllowDrop="True" Drop="NotesTree_Drop"
                                                  PreviewMouseMove="NotesTree_PreviewMouseMove"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Stretch"
                                      Background="#222222" Cursor="SizeWE"/>

                        <!-- EDITOR -->
                        <Grid Grid.Column="2" Background="#161616">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#141414" Padding="16,8">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button x:Name="BtnEditMode" Content="Edit" Style="{StaticResource ToolbarBtn}"
                                                Margin="0,0,4,0" Height="26" FontSize="11" Click="SwitchToEdit_Click"/>
                                        <Button x:Name="BtnPreviewMode" Content="Preview" Style="{StaticResource GhostBtn}"
                                                Margin="0,0,4,0" Height="26" FontSize="11" Click="SwitchToPreview_Click"/>
                                        <Button Content="History" Style="{StaticResource GhostBtn}"
                                                Margin="0,0,4,0" Height="26" FontSize="11" Click="ShowHistory_Click"/>
                                        <Button x:Name="BtnPinNote" Content="📌" Style="{StaticResource GhostBtn}"
                                                Margin="0,0,4,0" Height="26" FontSize="11" Click="TogglePinNote_Click" ToolTip="Pin note"/>
                                        <Button Content="Delete" Style="{StaticResource DangerBtn}"
                                                Height="26" FontSize="11" Click="DeleteNote_Click"/>
                                    </StackPanel>
                                    <TextBlock x:Name="NoteEditorTitle" Text="Select or create a note"
                                               FontSize="13" Foreground="#555555" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <Grid x:Name="EditPanel" Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="28,18,28,0" Background="#161616">
                                    <TextBox x:Name="NoteTitleEditor" FontSize="24" FontWeight="SemiBold"
                                             Foreground="#E8E8E8" CaretBrush="#7C3AED"
                                             Background="Transparent" BorderThickness="0"
                                             SelectionBrush="#7C3AED" TextChanged="NoteContent_Changed"/>
                                </Border>
                                <TextBox x:Name="NoteBodyEditor" Grid.Row="1"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#161616" Foreground="#CCCCCC"
                                         CaretBrush="#7C3AED" SelectionBrush="#7C3AED"
                                          BorderThickness="0" FontFamily="Consolas" FontSize="14"
                                          Padding="28,14" TextChanged="NoteContent_Changed"
                                          AllowDrop="True" Drop="NoteBodyEditor_Drop"
                                          SpellCheck.IsEnabled="True"/>
                            </Grid>
                            <ScrollViewer x:Name="PreviewPanel" Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                                          Background="#161616" Padding="28,18">
                                <RichTextBox x:Name="PreviewBox" Background="Transparent"
                                             BorderThickness="0" Foreground="#CCCCCC"
                                             FontSize="14" IsReadOnly="True" FontFamily="Segoe UI"/>
                            </ScrollViewer>
                            <Border Grid.Row="2" Background="#141414" Padding="16,5">
                                <DockPanel>
                                    <TextBlock x:Name="NoteWordCount" Text="0 words"
                                               Foreground="#444444" FontSize="11" DockPanel.Dock="Right"/>
                                    <TextBlock x:Name="NoteSaveStatus" Text="No note open"
                                               Foreground="#444444" FontSize="11"/>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <GridSplitter Grid.Column="3" Width="3" HorizontalAlignment="Stretch"
                                      Background="#222222" Cursor="SizeWE"/>

                        <!-- METADATA -->
                        <Border Grid.Column="4" Background="#141414">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16,16">
                                    <TextBlock Text="NOTE INFO" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#444444" Margin="0,0,0,12"/>
                                    <TextBlock Text="Created" FontSize="11" Foreground="#555555"/>
                                    <TextBlock x:Name="NoteCreatedText" Text="—" FontSize="12" Foreground="#888888" Margin="0,2,0,12"/>
                                    <TextBlock Text="Modified" FontSize="11" Foreground="#555555"/>
                                    <TextBlock x:Name="NoteModifiedText" Text="—" FontSize="12" Foreground="#888888" Margin="0,2,0,12"/>
                                    <TextBlock Text="Folder" FontSize="11" Foreground="#555555"/>
                                    <TextBlock x:Name="NoteFolderText" Text="—" FontSize="12" Foreground="#888888" Margin="0,2,0,12"/>
                                    <TextBlock Text="Words" FontSize="11" Foreground="#555555"/>
                                    <TextBlock x:Name="NoteWordCountPanel" Text="—" FontSize="12" Foreground="#888888" Margin="0,2,0,24"/>
                                    <Rectangle Height="1" Fill="#222222" Margin="0,0,0,16"/>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="TAGS" FontSize="10" FontWeight="SemiBold" Foreground="#444444"/>
                                        <Button DockPanel.Dock="Right" Content="+ Tag" Height="20" Padding="6,0"
                                                FontSize="10" Style="{StaticResource GhostBtn}"
                                                Click="AddTagToNote_Click"/>
                                    </DockPanel>
                                     <WrapPanel x:Name="NoteTagsPanel" Margin="0,0,0,16"/>
                                     <Rectangle Height="1" Fill="#222222" Margin="0,0,0,16"/>
                                    <TextBlock Text="ATTACHMENTS" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,8"/>
                                    <Button Content="+ Attach File" Style="{StaticResource GhostBtn}" Height="24" FontSize="11"
                                            Margin="0,0,0,8" Click="AttachFile_Click"/>
                                    <ListBox x:Name="AttachmentsList" Background="Transparent" BorderThickness="0"
                                             Margin="0,0,0,16" MouseDoubleClick="Attachment_DoubleClick"/>
                                    <Rectangle Height="1" Fill="#222222" Margin="0,0,0,16"/>
                                     <TextBlock Text="OUTLINE" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,12"/>
                                    <ListBox x:Name="OutlineList" Background="Transparent" BorderThickness="0"
                                             ItemContainerStyle="{StaticResource NoteFileItem}"
                                             SelectionChanged="OutlineList_Click">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Rectangle Height="1" Fill="#222222" Margin="0,16,0,16"/>
                                    <TextBlock Text="BACKLINKS" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,8"/>
                                    <TextBlock Text="Notes linking here:" FontSize="11" Foreground="#555555" Margin="0,0,0,6"/>
                                    <ListBox x:Name="BacklinksList" Background="Transparent" BorderThickness="0"
                                             ItemContainerStyle="{StaticResource NoteFileItem}"
                                             MouseDoubleClick="Backlink_DoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Title}" FontSize="12"
                                                           TextTrimming="CharacterEllipsis" Foreground="#7C3AED"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Rectangle Height="1" Fill="#222222" Margin="0,16,0,16"/>
                                    <TextBlock Text="MARKDOWN GUIDE" FontSize="10" FontWeight="SemiBold"
                                               Foreground="#444444" Margin="0,0,0,10"/>
                                    <TextBlock Foreground="#444444" FontSize="11" FontFamily="Consolas">
                                        <Run Text="# Heading 1"/><LineBreak/>
                                        <Run Text="## Heading 2"/><LineBreak/>
                                        <Run Text="**bold**"/><LineBreak/>
                                        <Run Text="*italic*"/><LineBreak/>
                                        <Run Text="- list item"/><LineBreak/>
                                        <Run Text="1. numbered"/><LineBreak/>
                                        <Run Text="`inline code`"/><LineBreak/>
                                        <Run Text="---  (divider)"/>
                                    </TextBlock>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- GRAPH VIEW - Obsidian style -->
                    <Grid x:Name="GraphView" Visibility="Collapsed" Background="#161616">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#141414" Padding="16,10">
                            <DockPanel>
                                <TextBlock Text="Graph View" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#E8E8E8" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                    <Button Content="Reset" Style="{StaticResource GhostBtn}"
                                            Height="26" FontSize="11" Margin="0,0,6,0" Click="GraphReset_Click"/>
                                    <TextBlock Text="Scroll to zoom  ·  Drag to pan  ·  Double-click node to open"
                                               Foreground="#444444" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <Canvas x:Name="GraphCanvas" Grid.Row="1" Background="#161616"
                                MouseDown="GraphCanvas_MouseDown"
                                MouseMove="GraphCanvas_MouseMove"
                                MouseUp="GraphCanvas_MouseUp"
                                MouseWheel="GraphCanvas_MouseWheel"
                                ClipToBounds="True">
                            <Canvas x:Name="GraphInnerCanvas"/>
                        </Canvas>
                    </Grid>

                    <!-- SECURITY VIEW -->
                    <Grid x:Name="SecurityView" Visibility="Collapsed" Background="#161616">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#141414" Padding="16,10">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="Security Insights" FontSize="15" FontWeight="SemiBold" Foreground="#E8E8E8" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="Run Check" Style="{StaticResource ToolbarBtn}" Height="28" MinWidth="96" Click="RunSecurityCheck_Click"/>
                            </DockPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="24">
                            <StackPanel MaxWidth="640">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                    <Border Width="140" Height="90" CornerRadius="8" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,0,12,0">
                                        <StackPanel VerticalAlignment="Center" Margin="16,0">
                                            <TextBlock x:Name="WeakCount" Text="—" FontSize="28" FontWeight="Bold" Foreground="#EF4444"/>
                                            <TextBlock Text="Weak" FontSize="12" Foreground="#555555"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Width="140" Height="90" CornerRadius="8" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,0,12,0">
                                        <StackPanel VerticalAlignment="Center" Margin="16,0">
                                            <TextBlock x:Name="ReusedCount" Text="—" FontSize="28" FontWeight="Bold" Foreground="#F59E0B"/>
                                            <TextBlock Text="Reused" FontSize="12" Foreground="#555555"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Width="140" Height="90" CornerRadius="8" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="1">
                                        <StackPanel VerticalAlignment="Center" Margin="16,0">
                                            <TextBlock x:Name="DupeCount" Text="—" FontSize="28" FontWeight="Bold" Foreground="#7C3AED"/>
                                            <TextBlock Text="Duplicates" FontSize="12" Foreground="#555555"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <TextBlock x:Name="SecurityTitle" Text="WEAK PASSWORDS" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,10"/>
                                <ListView x:Name="SecurityList" Style="{StaticResource DarkList}" ItemContainerStyle="{StaticResource DarkListItem}" MaxHeight="320">
                                    <ListView.View>
                                        <GridView>
                                            <GridView.ColumnHeaderContainerStyle>
                                                <Style TargetType="GridViewColumnHeader">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#555555"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="8,6"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="GridViewColumnHeader">
                                                                <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                    <TextBlock Text="{TemplateBinding Content}" Foreground="#555555" FontSize="11" FontWeight="SemiBold"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </GridView.ColumnHeaderContainerStyle>
                                            <GridViewColumn Header="TITLE" Width="200" DisplayMemberBinding="{Binding Title}"/>
                                            <GridViewColumn Header="USERNAME" Width="180" DisplayMemberBinding="{Binding Username}"/>
                                            <GridViewColumn Header="STRENGTH" Width="140" DisplayMemberBinding="{Binding StrengthLabel}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Content="Weak" Style="{StaticResource GhostBtn}" Margin="0,0,8,0" Click="ShowWeak_Click" Height="28" FontSize="11"/>
                                    <Button Content="Reused" Style="{StaticResource GhostBtn}" Margin="0,0,8,0" Click="ShowReused_Click" Height="28" FontSize="11"/>
                                    <Button Content="Duplicates" Style="{StaticResource GhostBtn}" Margin="0,0,8,0" Click="ShowDupes_Click" Height="28" FontSize="11"/>
                                    <Button Content="Breach Check" Style="{StaticResource GhostBtn}" Click="RunBreachCheck_Click" Height="28" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- TRASH VIEW -->
                    <Grid x:Name="TrashView" Visibility="Collapsed" Background="#161616">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#141414" Padding="16,10">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="Trash" FontSize="15" FontWeight="SemiBold" Foreground="#E8E8E8" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="Empty Trash" Style="{StaticResource DangerBtn}" Height="28" MinWidth="104" Click="EmptyTrash_Click"/>
                            </DockPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1" Padding="16">
                            <StackPanel>
                                <TextBlock Text="DELETED PASSWORDS" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,10"/>
                                <ListBox x:Name="TrashPasswordsList" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource NoteFileItem}" Margin="0,0,0,20">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Restore" Style="{StaticResource GhostBtn}" Height="24" FontSize="11" Padding="8,0" Tag="{Binding}" Click="RestorePassword_Click"/>
                                                <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#BBBBBB" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="DELETED NOTES" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,10"/>
                                <ListBox x:Name="TrashNotesList" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource NoteFileItem}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Restore" Style="{StaticResource GhostBtn}" Height="24" FontSize="11" Padding="8,0" Tag="{Binding}" Click="RestoreNote_Click"/>
                                                <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#BBBBBB" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- SETTINGS -->
                    <Grid x:Name="SettingsView" Visibility="Collapsed" Background="#161616">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="SettingsHeader" Grid.Row="0" Background="#141414" Padding="16,10">
                            <TextBlock Text="Settings" FontSize="15" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                        </Border>
                        <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="1" Padding="32,24">
                            <StackPanel MaxWidth="500">
                                <TextBlock Text="VAULT" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,12"/>
                                <Button Content="Import passwords from CSV" Style="{StaticResource GhostBtn}"
                                        HorizontalAlignment="Left" Height="32" Padding="16,0"
                                        Click="ImportCsv_Click" Margin="0,0,0,8"/>
                                <Button Content="Export encrypted share" Style="{StaticResource GhostBtn}"
                                        HorizontalAlignment="Left" Height="32" Padding="16,0"
                                        Click="ExportEncryptedShare_Click" Margin="0,0,0,8"/>
                                <Button Content="Import encrypted share" Style="{StaticResource GhostBtn}"
                                        HorizontalAlignment="Left" Height="32" Padding="16,0"
                                        Click="ImportEncryptedShare_Click" Margin="0,0,0,8"/>
                                <Button Content="How encrypted shares work" Style="{StaticResource GhostBtn}"
                                        HorizontalAlignment="Left" Height="32" Padding="16,0"
                                        Click="ShowEncryptedShareInfo_Click" Margin="0,0,0,8"/>
                                <TextBlock Text="Encrypted shares are .bastion-share files containing a password-protected copy of passwords and notes. To import one, choose the file, enter the password used when it was exported, and Bastion merges non-duplicate items into this vault."
                                           Foreground="#555555" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <Rectangle Height="1" Fill="#222222" Margin="0,20,0,20"/>

                                <TextBlock Text="AUTO-LOCK" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,8"/>
                                <TextBlock Text="Lock vault after inactivity:" Foreground="#777777" FontSize="13" Margin="0,0,0,10"/>
                                <ComboBox x:Name="LockTimeoutCombo" Style="{StaticResource DarkCombo}"
                                          Width="220" HorizontalAlignment="Left"
                                          SelectionChanged="LockTimeout_Changed">
                                    <ComboBoxItem Content="1 minute" Tag="1"/>
                                    <ComboBoxItem Content="2 minutes" Tag="2"/>
                                    <ComboBoxItem Content="3 minutes" Tag="3" IsSelected="True"/>
                                    <ComboBoxItem Content="5 minutes" Tag="5"/>
                                    <ComboBoxItem Content="10 minutes" Tag="10"/>
                                    <ComboBoxItem Content="15 minutes" Tag="15"/>
                                    <ComboBoxItem Content="30 minutes" Tag="30"/>
                                    <ComboBoxItem Content="Never" Tag="0"/>
                                </ComboBox>

                                <Rectangle Height="1" Fill="#222222" Margin="0,20,0,20"/>
                                <TextBlock Text="BROWSER EXTENSION" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,8"/>
                                <TextBlock Text="Enable autofill in Chrome or Firefox using the Bastion extension." Foreground="#777777" FontSize="13" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                <CheckBox x:Name="AutofillEnabledCheck" Content="Enable browser autofill" Foreground="#999999"
                                          Margin="0,0,0,10" Checked="AutofillEnabled_Changed" Unchecked="AutofillEnabled_Changed"/>
                                <Button Content="Show Session Token" Style="{StaticResource GhostBtn}"
                                        HorizontalAlignment="Left" Height="32" Padding="16,0"
                                        Click="ShowAutofillToken_Click" Margin="0,0,0,6"/>
                                <TextBlock Text="Load the BrowserExtension/ folder as an unpacked extension in Chrome (chrome://extensions → Load unpacked) or Firefox (about:debugging → Load Temporary Add-on)."
                                           Foreground="#444444" FontSize="11" TextWrapping="Wrap"/>

                                <Rectangle Height="1" Fill="#222222" Margin="0,20,0,20"/>
                                <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,12"/>
                                <CheckBox x:Name="DarkThemeCheck" Content="Dark theme" Foreground="#999999"
                                          Margin="0,0,0,8" Checked="Theme_Changed" Unchecked="Theme_Changed"/>
                                <TextBlock Text="Accent color" Foreground="#777777" FontSize="13" Margin="0,0,0,6"/>
                                <TextBox x:Name="AccentColorBox" Style="{StaticResource DarkInput}" Width="120" HorizontalAlignment="Left"
                                         TextChanged="AccentColor_Changed" Margin="0,0,0,10"/>

                                <Rectangle Height="1" Fill="#222222" Margin="0,20,0,20"/>
                                <TextBlock Text="GRAPH COLORS" FontSize="10" FontWeight="SemiBold" Foreground="#444444" Margin="0,0,0,12"/>
                                <TextBlock Text="Customize node and line colors in the graph view." Foreground="#777777" FontSize="13" Margin="0,0,0,10"/>
                                <Button Content="Open Color Settings" Style="{StaticResource GhostBtn}"
                                        HorizontalAlignment="Left" Height="32" Padding="16,0"
                                        Click="OpenGraphColors_Click"/>
                                <TextBlock Foreground="#555555" FontSize="13">
                                    <Run Text="Bastion v2.9.15  ·  AES-256-GCM  ·  Local-first"/>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
