<Window x:Class="SecureVault.GraphColorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Graph Colors" Width="420" Height="480"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="Transparent">

    <Border CornerRadius="10" Background="#1A1A1A" BorderBrush="#2D2D2D" BorderThickness="1">
        <DockPanel>
            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Background="#141414" Height="36" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="Graph Color Settings" Foreground="#666666" FontSize="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Content="✕" Width="28" Height="24" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,6,0" Cursor="Hand"
                            Click="Cancel_Click" Foreground="#555555" Background="Transparent"
                            BorderThickness="0" FontSize="11"/>
                </Grid>
            </Border>

            <StackPanel Margin="24,20,24,20">
                <TextBlock Text="NODE COLOR" FontSize="10" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,10"/>
                <TextBlock Text="Standard nodes" FontSize="12" Foreground="#777777" Margin="0,0,0,8"/>
                <WrapPanel x:Name="NodeColorPanel" Margin="0,0,0,20"/>

                <TextBlock Text="HUB NODE COLOR" FontSize="10" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,10"/>
                <TextBlock Text="Nodes with 4+ connections" FontSize="12" Foreground="#777777" Margin="0,0,0,8"/>
                <WrapPanel x:Name="HubColorPanel" Margin="0,0,0,20"/>

                <TextBlock Text="LINE COLOR" FontSize="10" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,10"/>
                <TextBlock Text="Connection lines between notes" FontSize="12" Foreground="#777777" Margin="0,0,0,8"/>
                <WrapPanel x:Name="LineColorPanel" Margin="0,0,0,28"/>

                <!-- Preview -->
                <Border CornerRadius="6" Background="#111111" BorderBrush="#2A2A2A" BorderThickness="1"
                        Height="70" Margin="0,0,0,24">
                    <Canvas x:Name="PreviewCanvas"/>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="88" Height="34" Margin="0,0,8,0" Click="Cancel_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#777777"/>
                                <Setter Property="BorderBrush" Value="#333333"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Apply" Width="88" Height="34" Click="Apply_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#7C3AED"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#6D28D9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
