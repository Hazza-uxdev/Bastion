<Window x:Class="SecureVault.EntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Entry" Height="500" Width="500"
        Background="Transparent"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FlatInput" TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="CaretBrush" Value="#7C3AED"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionBrush" Value="#7C3AED"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter TargetName="Bd" Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6D28D9"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#777777"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252525"/>
                                <Setter Property="Foreground" Value="#BBBBBB"/>
                                <Setter Property="BorderBrush" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="10" Background="#1A1A1A">
        <DockPanel>
            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Background="#141414" Height="36" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="14,0">
                        <Border Width="22" Height="22" CornerRadius="5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#4C1D95" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🔐" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Password Entry" Foreground="#666666" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Width="28" Height="24" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,6,0" Cursor="Hand"
                            Click="Cancel_Click" Style="{StaticResource GhostBtn}"
                            Padding="0,0" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Bottom button row docked so it's always visible -->
            <Border DockPanel.Dock="Bottom" Padding="24,12,24,16" Background="#1A1A1A">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="96" Margin="0,0,10,0"
                            Click="Cancel_Click" Style="{StaticResource GhostBtn}"/>
                    <Button Content="Save" Width="96"
                            Click="Ok_Click" Style="{StaticResource ActionBtn}"/>
                </StackPanel>
            </Border>

            <!-- Form fields -->
            <ScrollViewer Margin="24,16,24,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="TITLE" FontSize="10" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,6"/>
                <TextBox Name="TitleBox" Style="{StaticResource FlatInput}" Margin="0,0,0,12"/>

                <TextBlock Text="USERNAME" FontSize="10" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,6"/>
                <TextBox Name="UsernameBox" Style="{StaticResource FlatInput}" Margin="0,0,0,12"/>

                <TextBlock Text="WEBSITE" FontSize="10" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,6"/>
                <TextBox Name="UrlBox" Style="{StaticResource FlatInput}" Margin="0,0,0,12"/>

                <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <Border CornerRadius="5" BorderBrush="#3A3A3A" BorderThickness="1"
                            Background="#252525" Height="36" Width="176">
                        <PasswordBox Name="PasswordBox" Background="Transparent"
                                     BorderThickness="0" Foreground="#E8E8E8"
                                     CaretBrush="#7C3AED" Padding="10,0" FontSize="13"
                                     VerticalContentAlignment="Center"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                    </Border>
                    <Button Content="Generate" Margin="6,0,0,0" Padding="12,0"
                            Click="GeneratePassword_Click" Style="{StaticResource ActionBtn}"/>
                    <Button Content="Copy" Margin="4,0,0,0" Padding="10,0"
                            Click="CopyPassword_Click" Style="{StaticResource GhostBtn}"/>
                </StackPanel>
                <TextBlock x:Name="StrengthText" Text="Strength: -" FontSize="11" Foreground="#777777" Margin="0,6,0,12"/>

                <TextBlock Text="TAGS" FontSize="10" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,6"/>
                <TextBox Name="TagsBox" Style="{StaticResource FlatInput}" Margin="0,0,0,6"
                         ToolTip="Comma-separated tags, for example work, finance"/>
                <TextBlock Text="Use comma-separated tags. Existing tags can be reused." FontSize="11" Foreground="#555555" Margin="0,0,0,12"/>

                <TextBlock Text="2FA / TOTP SECRET" FontSize="10" FontWeight="SemiBold" Foreground="#555555" Margin="0,0,0,6"/>
                <TextBox Name="TotpSecretBox" Style="{StaticResource FlatInput}" Margin="0,0,0,6"
                         TextChanged="TotpSecretBox_TextChanged"
                         ToolTip="Paste a Base32 secret or otpauth:// URI"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="Paste setup URI" Style="{StaticResource GhostBtn}" Height="28" Padding="10,0"
                            Click="PasteTotpUri_Click" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TotpPreviewText" Text="No 2FA code configured" FontSize="11"
                               Foreground="#777777" VerticalAlignment="Center"/>
                </StackPanel>

                <Expander Header="Password generator settings" Foreground="#777777" Margin="0,0,0,8">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="Length" FontSize="11" Foreground="#555555" Margin="0,0,0,4"/>
                        <TextBox Name="GeneratorLengthBox" Style="{StaticResource FlatInput}" Width="80" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <CheckBox Name="UppercaseCheck" Content="Uppercase" Foreground="#999999" Margin="0,0,12,6"/>
                            <CheckBox Name="LowercaseCheck" Content="Lowercase" Foreground="#999999" Margin="0,0,12,6"/>
                            <CheckBox Name="DigitsCheck" Content="Digits" Foreground="#999999" Margin="0,0,12,6"/>
                            <CheckBox Name="SymbolsCheck" Content="Symbols" Foreground="#999999" Margin="0,0,12,6"/>
                        </WrapPanel>
                    </StackPanel>
                </Expander>
            </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
